---
/**
 * @package GIALLORO-FIRENZE — Service Card
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Card servizio con icona SVG inline, titolo, descrizione, CTA.
 *          Hover luxury (shift up + gold border). Zero JS.
 */
export interface Props {
  title: string;
  description: string;
  href: string;
  ctaLabel: string;
  icon: 'scale' | 'bar' | 'gem' | 'stamp';
}
const { title, description, href, ctaLabel, icon } = Astro.props;

const icons: Record<typeof icon, string> = {
  scale: `<path d="M3 20h18M12 4v16M5 4l7 8 7-8M5 4l-2 6h4M19 4l2 6h-4"/>`,
  bar: `<rect x="3" y="10" width="18" height="8" rx="1"/><path d="M6 10V7a2 2 0 012-2h8a2 2 0 012 2v3"/><path d="M8 14h8"/>`,
  gem: `<path d="M12 2l4 6-4 14-4-14z"/><path d="M8 8h8"/><path d="M4 8h16"/>`,
  stamp: `<path d="M5 22h14M7 18h10l-1-4H8z"/><circle cx="12" cy="7" r="4"/>`,
};
---
<a href={href} class="card-lux block p-7 md:p-8 group relative overflow-hidden h-full">
  <div class="absolute top-0 right-0 w-20 h-20 bg-gold-500/0 group-hover:bg-gold-500/5 rounded-bl-full transition-colors duration-500"></div>

  <div class="w-14 h-14 rounded-sm bg-gold-50 border border-gold-200 flex items-center justify-center mb-6 text-gold-700 group-hover:bg-gold-500 group-hover:text-ink-900 group-hover:border-gold-600 transition-colors duration-300">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[icon]} />
  </div>

  <h3 class="serif text-2xl md:text-[26px] font-semibold text-ink-900 mb-3 group-hover:text-gold-700 transition-colors">
    {title}
  </h3>

  <p class="text-ink-600 leading-relaxed mb-6 text-[15px]">
    {description}
  </p>

  <span class="inline-flex items-center gap-2 text-sm font-semibold text-gold-700 uppercase tracking-wider">
    {ctaLabel}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform group-hover:translate-x-1" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
  </span>
</a>
