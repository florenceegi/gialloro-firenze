---
/**
 * @package GIALLORO-FIRENZE — Contact Form
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Form richiesta valutazione/contatto. POST a /mail.php con:
 *          - CSRF token (field hidden + cookie per validation server-side)
 *          - Honeypot campo nascosto ("website")
 *          - Validation HTML5 nativa + ARIA
 *          Success/error UI gestita client-side, ma form funziona anche senza JS.
 */
import { t, type Locale } from '@i18n/index';

export interface Props { locale: Locale; }
const { locale } = Astro.props;

// Token simple-ma-efficace: hash del timestamp iniziale (build time).
// Per protezione reale affidabile serve session server-side (mail.php lo valida su timestamp+HMAC).
const buildNonce = Math.random().toString(36).slice(2, 14);
---
<section class="max-w-3xl mx-auto">
  <div class="mb-8 text-center">
    <h2 class="serif text-4xl md:text-5xl text-ink-900 mb-3">{t(locale, 'form.title')}</h2>
    <p class="text-ink-600 text-lg">{t(locale, 'form.subtitle')}</p>
  </div>

  <form
    action="/mail.php"
    method="POST"
    class="card-lux p-6 md:p-10 space-y-5"
    novalidate
    data-contact-form
    aria-label={t(locale, 'form.title')}
  >
    <input type="hidden" name="_nonce" value={buildNonce} />
    <input type="hidden" name="_locale" value={locale} />
    <!-- honeypot -->
    <div class="absolute -left-[9999px] w-px h-px overflow-hidden" aria-hidden="true">
      <label>Website <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      <div>
        <label for="f-name" class="block text-sm font-semibold text-ink-800 mb-2">{t(locale, 'form.name')} *</label>
        <input id="f-name" name="name" type="text" required minlength="2" maxlength="80"
          placeholder={t(locale, 'form.name_ph')}
          class="w-full px-4 py-3 bg-ivory-50 border border-ink-200 rounded-sm focus:border-gold-500 focus:bg-white outline-none transition-colors" />
      </div>
      <div>
        <label for="f-phone" class="block text-sm font-semibold text-ink-800 mb-2">{t(locale, 'form.phone')} *</label>
        <input id="f-phone" name="phone" type="tel" required minlength="6" maxlength="25"
          placeholder={t(locale, 'form.phone_ph')}
          class="w-full px-4 py-3 bg-ivory-50 border border-ink-200 rounded-sm focus:border-gold-500 focus:bg-white outline-none transition-colors tabular" />
      </div>
    </div>

    <div>
      <label for="f-email" class="block text-sm font-semibold text-ink-800 mb-2">{t(locale, 'form.email')} *</label>
      <input id="f-email" name="email" type="email" required maxlength="120"
        placeholder={t(locale, 'form.email_ph')}
        class="w-full px-4 py-3 bg-ivory-50 border border-ink-200 rounded-sm focus:border-gold-500 focus:bg-white outline-none transition-colors" />
    </div>

    <div>
      <label for="f-subject" class="block text-sm font-semibold text-ink-800 mb-2">{t(locale, 'form.subject')} *</label>
      <input id="f-subject" name="subject" type="text" required minlength="3" maxlength="120"
        placeholder={t(locale, 'form.subject_ph')}
        class="w-full px-4 py-3 bg-ivory-50 border border-ink-200 rounded-sm focus:border-gold-500 focus:bg-white outline-none transition-colors" />
    </div>

    <div>
      <label for="f-message" class="block text-sm font-semibold text-ink-800 mb-2">{t(locale, 'form.message')}</label>
      <textarea id="f-message" name="message" rows="4" maxlength="2000"
        placeholder={t(locale, 'form.message_ph')}
        class="w-full px-4 py-3 bg-ivory-50 border border-ink-200 rounded-sm focus:border-gold-500 focus:bg-white outline-none transition-colors resize-y"></textarea>
    </div>

    <label class="flex items-start gap-3 text-sm text-ink-600">
      <input type="checkbox" name="privacy" required class="mt-1 w-4 h-4 accent-gold-500" />
      <span>
        {t(locale, 'form.privacy')}
        <a href={locale === 'it' ? '/privacy' : '/en/privacy'} class="text-gold-700 lux-link">({t(locale, 'form.privacy_link')})</a>
      </span>
    </label>

    <div class="pt-2 flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
      <button type="submit" class="btn-gold flex-1 sm:flex-none" data-submit-btn>
        <span data-submit-text>{t(locale, 'form.submit')}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </button>
      <a href="https://wa.me/393917792818" target="_blank" rel="noopener" class="btn-ghost">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
        {t(locale, 'cta.whatsapp')}
      </a>
    </div>

    <div data-form-status role="status" aria-live="polite" class="hidden"></div>
  </form>
</section>

<script is:inline>
(function() {
  const form = document.querySelector('[data-contact-form]');
  if (!form) return;
  const statusEl = form.querySelector('[data-form-status]');
  const btn = form.querySelector('[data-submit-btn]');
  const btnText = form.querySelector('[data-submit-text]');
  const defaultText = btnText ? btnText.textContent : '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    if (form.querySelector('[name=website]').value) return; // honeypot triggered

    if (btnText) btnText.textContent = form.getAttribute('data-sending-text') || 'Invio…';
    if (btn) btn.setAttribute('disabled', 'true');

    try {
      const res = await fetch('/mail.php', {
        method: 'POST',
        body: new FormData(form),
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
      });
      const json = await res.json().catch(() => ({ ok: res.ok }));
      if (res.ok && json.ok !== false) {
        form.reset();
        statusEl.className = 'p-4 rounded-sm bg-green-50 border border-green-200 text-green-900 text-sm';
        statusEl.innerHTML = '<strong class="block mb-1">' + (form.dataset.successTitle || 'OK') + '</strong>' + (form.dataset.successText || '');
      } else {
        throw new Error(json.error || 'server');
      }
    } catch (err) {
      statusEl.className = 'p-4 rounded-sm bg-red-50 border border-red-200 text-red-900 text-sm';
      statusEl.innerHTML = '<strong class="block mb-1">' + (form.dataset.errorTitle || 'Error') + '</strong>' + (form.dataset.errorText || '');
    } finally {
      if (btnText) btnText.textContent = defaultText;
      if (btn) btn.removeAttribute('disabled');
    }
  });
})();
</script>
