---
/**
 * @package GIALLORO-FIRENZE — Hero Cinematografico
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 2.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Hero editoriale luxury con particles oro, coin rotante, counter animate,
 *          gradient wave ambient, parallax scroll, magnetic CTA, reveal stagger.
 *          Performance-first: canvas particles lazy, GPU transforms, reduced-motion safe.
 */
import { t, hrefFor, type Locale } from '@i18n/index';

export interface Props { locale: Locale; }
const { locale } = Astro.props;

const contattiHref = locale === 'it' ? '/contatti' : '/en/contact';
const quotazioniHref = locale === 'it' ? '/quotazioni' : '/en/live-price';
---
<section id="hero" class="hero-cinema relative overflow-hidden pt-10 md:pt-16 lg:pt-24 pb-16 md:pb-24 lg:pb-32 min-h-[88vh] flex items-center">
  <!-- Ambient gradient wave (CSS animation) -->
  <div class="hero-wave absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Canvas particles gold (lazy) -->
  <canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none opacity-0 transition-opacity duration-1000" aria-hidden="true"></canvas>

  <!-- Deco SVG parallax layers -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="hero-parallax absolute -top-20 -right-20 w-[540px] h-[540px] opacity-40" data-speed="0.3" viewBox="0 0 600 600" fill="none">
      <defs>
        <radialGradient id="h-grad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#d4af37" stop-opacity="0.32"/>
          <stop offset="60%" stop-color="#d4af37" stop-opacity="0.08"/>
          <stop offset="100%" stop-color="#d4af37" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="300" cy="300" r="280" fill="url(#h-grad)"/>
    </svg>
    <svg class="hero-parallax absolute bottom-0 -left-40 w-[440px] h-[440px] opacity-50" data-speed="0.5" viewBox="0 0 500 500" fill="none">
      <circle cx="250" cy="250" r="240" stroke="#d4af37" stroke-width="0.5" opacity="0.3" fill="none" class="hero-ring"/>
      <circle cx="250" cy="250" r="180" stroke="#d4af37" stroke-width="0.5" opacity="0.22" fill="none" class="hero-ring" style="animation-delay:0.4s"/>
      <circle cx="250" cy="250" r="120" stroke="#d4af37" stroke-width="0.5" opacity="0.15" fill="none" class="hero-ring" style="animation-delay:0.8s"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 md:px-8 grid lg:grid-cols-12 gap-8 lg:gap-16 items-center w-full">
    <!-- Left: copy -->
    <div class="lg:col-span-7">
      <!-- Eyebrow -->
      <div class="reveal reveal-up inline-flex items-center gap-2 mb-6 pl-4 pr-4 py-1.5 border border-gold-400/50 rounded-full bg-white/70 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse"></span>
        <span class="text-[11px] uppercase tracking-[0.24em] text-ink-800 font-medium">
          {t(locale, 'hero.eyebrow')}
        </span>
      </div>

      <!-- H1 -->
      <h1 class="serif text-5xl md:text-6xl lg:text-7xl xl:text-[5.5rem] leading-[0.98] tracking-tight mb-6">
        <span class="reveal reveal-up block text-ink-900" style="--reveal-delay:60ms">{t(locale, 'hero.title_top')}</span>
        <span class="reveal reveal-up block my-1" style="--reveal-delay:180ms">
          <span class="relative inline-block">
            <span class="italic text-gold-700 hero-shimmer">{t(locale, 'hero.title_accent')}</span>
            <svg class="hero-underline absolute -bottom-2 left-0 w-full h-4" viewBox="0 0 300 20" fill="none" aria-hidden="true" preserveAspectRatio="none">
              <path d="M2 14 Q 75 4 150 10 T 298 10" stroke="#d4af37" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
          </span>
        </span>
        <span class="reveal reveal-up block text-ink-900" style="--reveal-delay:320ms">{t(locale, 'hero.title_bottom')}</span>
      </h1>

      <!-- Subtitle (answer-first, 40 word rule) -->
      <p class="reveal reveal-up text-lg md:text-xl text-ink-600 leading-relaxed max-w-2xl mb-9" style="--reveal-delay:460ms">
        {t(locale, 'hero.subtitle')}
      </p>

      <!-- CTA -->
      <div class="reveal reveal-up flex flex-col sm:flex-row gap-3 sm:gap-4 mb-12" style="--reveal-delay:600ms">
        <a href={contattiHref} class="btn-gold btn-magnetic group">
          <span class="relative z-10">{t(locale, 'hero.cta_primary')}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="relative z-10 transition-transform group-hover:translate-x-1" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={quotazioniHref} class="btn-ghost btn-magnetic">{t(locale, 'hero.cta_secondary')}</a>
      </div>

      <!-- Trust row with animated counters -->
      <div class="reveal reveal-up grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 pt-8 border-t border-ink-200/60" style="--reveal-delay:740ms">
        <div class="trust-item flex items-start gap-2.5">
          <svg class="text-gold-600 mt-0.5 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span class="text-xs md:text-sm font-medium text-ink-800">{t(locale, 'hero.trust_oam')}</span>
        </div>
        <div class="trust-item flex items-start gap-2.5">
          <svg class="text-gold-600 mt-0.5 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span class="text-xs md:text-sm font-medium text-ink-800"><span class="counter tabular" data-target="18" data-suffix="+ anni">0</span></span>
        </div>
        <div class="trust-item flex items-start gap-2.5">
          <svg class="text-gold-600 mt-0.5 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="text-xs md:text-sm font-medium text-ink-800"><span class="counter tabular" data-target="4.9" data-decimals="1" data-suffix="/5">0</span> · <span class="counter tabular" data-target="520" data-suffix="+">0</span></span>
        </div>
        <div class="trust-item flex items-start gap-2.5">
          <svg class="text-gold-600 mt-0.5 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20"/></svg>
          <span class="text-xs md:text-sm font-medium text-ink-800">{t(locale, 'hero.trust_payment')}</span>
        </div>
      </div>
    </div>

    <!-- Right: cinematic art composition -->
    <div class="lg:col-span-5 relative hidden lg:block">
      <div class="relative aspect-square max-w-lg mx-auto hero-stage">
        <!-- Double frame depth -->
        <div class="absolute inset-6 border border-gold-500/40 rounded-sm hero-float" style="animation-delay:-1s"></div>
        <div class="absolute inset-0 border-2 border-gold-500 rounded-sm transform translate-x-3 translate-y-3 hero-float"></div>

        <!-- Card -->
        <div class="absolute inset-0 bg-white rounded-sm shadow-gold-lg flex items-center justify-center overflow-hidden hero-tilt">
          <svg viewBox="0 0 400 400" class="w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="bar-grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#fef3c7"/>
                <stop offset="45%" stop-color="#fcd34d"/>
                <stop offset="70%" stop-color="#d4af37"/>
                <stop offset="100%" stop-color="#92760f"/>
              </linearGradient>
              <linearGradient id="bar-shine" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="rgba(255,255,255,0)"/>
                <stop offset="50%" stop-color="rgba(255,255,255,0.5)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
              </linearGradient>
              <linearGradient id="coin-grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#fef3c7"/>
                <stop offset="50%" stop-color="#fbbf24"/>
                <stop offset="100%" stop-color="#92760f"/>
              </linearGradient>
            </defs>
            <!-- Background rings rotating -->
            <g class="hero-spin-slow" style="transform-origin:200px 200px">
              <circle cx="200" cy="200" r="170" fill="none" stroke="#fef3c7" stroke-width="1"/>
              <circle cx="200" cy="200" r="145" fill="none" stroke="#fcd34d" stroke-width="0.5" stroke-dasharray="2 6"/>
            </g>
            <!-- Bar with shine sweep -->
            <g transform="translate(100,150) rotate(-8 100 50)" class="hero-bar">
              <rect x="0" y="0" width="200" height="100" rx="4" fill="url(#bar-grad)"/>
              <rect x="0" y="0" width="200" height="100" rx="4" fill="url(#bar-shine)" opacity="0.7" class="hero-shine"/>
              <text x="100" y="38" text-anchor="middle" font-family="Inter" font-size="10" font-weight="700" fill="#3f3405" letter-spacing="2">FINE GOLD</text>
              <text x="100" y="56" text-anchor="middle" font-family="Playfair Display" font-size="22" font-weight="700" fill="#3f3405">999.9</text>
              <text x="100" y="75" text-anchor="middle" font-family="Inter" font-size="8" fill="#6b5608" letter-spacing="1.5">LBMA GOOD DELIVERY</text>
              <text x="100" y="89" text-anchor="middle" font-family="Inter" font-size="7" fill="#6b5608" letter-spacing="1">100 g · Giallo Oro Firenze</text>
            </g>
            <!-- Coin 22kt rotating 3D -->
            <g transform="translate(250,80)" class="hero-coin-3d">
              <circle cx="40" cy="40" r="38" fill="url(#coin-grad)" stroke="#92760f" stroke-width="1"/>
              <circle cx="40" cy="40" r="32" fill="none" stroke="#92760f" stroke-width="0.5" stroke-dasharray="2 1"/>
              <text x="40" y="45" text-anchor="middle" font-family="Playfair Display" font-size="14" font-weight="700" fill="#3f3405">22kt</text>
            </g>
            <!-- Coin 24kt floating -->
            <g transform="translate(60,270)" class="hero-coin-float">
              <circle cx="40" cy="40" r="34" fill="url(#coin-grad)" stroke="#92760f" stroke-width="1"/>
              <text x="40" y="45" text-anchor="middle" font-family="Playfair Display" font-size="12" font-weight="700" fill="#3f3405">24kt</text>
            </g>
          </svg>
        </div>

        <!-- Live price badge floating -->
        <div class="absolute -bottom-6 -right-4 bg-ink-900 text-white px-5 py-3 rounded-sm shadow-gold-lg hero-badge">
          <div class="text-[10px] uppercase tracking-widest text-gold-400 mb-0.5">Fixing LBMA</div>
          <div class="tabular text-xl font-bold">€ <span id="hero-live-price">—</span>/g</div>
          <div class="text-[10px] text-ivory-200 mt-0.5"><span class="inline-block w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse mr-1"></span>live · 24kt</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-ink-400 hero-scroll-hint">
    <span class="text-[10px] uppercase tracking-widest">scroll</span>
    <span class="w-px h-8 bg-gradient-to-b from-gold-500 to-transparent"></span>
  </div>
</section>

<style>
  /* Ambient gradient wave */
  .hero-cinema { background: radial-gradient(ellipse at top right, rgba(212,175,55,0.08), transparent 60%), radial-gradient(ellipse at bottom left, rgba(252,211,77,0.05), transparent 55%), linear-gradient(135deg, #fdfbf5 0%, #f9f3e3 100%); }
  .hero-wave { background: conic-gradient(from 180deg at 50% 50%, transparent, rgba(212,175,55,0.04), transparent, rgba(252,211,77,0.04), transparent); animation: wave-rotate 40s linear infinite; }

  @keyframes wave-rotate { to { transform: rotate(360deg); } }
  @keyframes hero-float-y { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @keyframes hero-float-frame { 0%,100% { transform: translate(12px,12px); } 50% { transform: translate(10px,14px); } }
  @keyframes hero-ring-draw { from { stroke-dasharray: 0 2000; opacity: 0; } to { stroke-dasharray: 2000 0; opacity: 0.3; } }
  @keyframes hero-shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }
  @keyframes hero-spin { to { transform: rotate(360deg); } }
  @keyframes hero-coin-flip { 0%,100% { transform: perspective(400px) rotateY(0deg) translateY(0); } 50% { transform: perspective(400px) rotateY(180deg) translateY(-8px); } }
  @keyframes hero-bar-enter { from { opacity: 0; transform: translate(100px,150px) rotate(-8deg) scale(0.8); } to { opacity: 1; transform: translate(100px,150px) rotate(-8deg) scale(1); } }
  @keyframes hero-shine-sweep { 0% { transform: translateX(-200px); } 100% { transform: translateX(200px); } }
  @keyframes hero-scroll-bounce { 0%,100% { transform: translate(-50%, 0); opacity: 0.6; } 50% { transform: translate(-50%, 6px); opacity: 1; } }
  @keyframes hero-badge-in { from { opacity: 0; transform: translate(20px, 20px); } to { opacity: 1; transform: translate(0,0); } }

  .hero-float { animation: hero-float-frame 6s ease-in-out infinite; }
  .hero-ring { stroke-dasharray: 2000 0; animation: hero-ring-draw 2.4s cubic-bezier(0.22,1,0.36,1) both; }
  .hero-shimmer { background: linear-gradient(90deg, #92760f 0%, #d4af37 45%, #fcd34d 50%, #d4af37 55%, #92760f 100%); background-size: 200% auto; -webkit-background-clip: text; background-clip: text; color: transparent; animation: hero-shimmer 4s linear infinite; }
  .hero-spin-slow { animation: hero-spin 60s linear infinite; transform-box: fill-box; }
  .hero-coin-3d { transform-origin: 290px 120px; animation: hero-coin-flip 7s ease-in-out infinite; }
  .hero-coin-float { animation: hero-float-y 4s ease-in-out infinite; animation-delay: -2s; }
  .hero-shine { animation: hero-shine-sweep 3.5s ease-in-out infinite; }
  .hero-scroll-hint { animation: hero-scroll-bounce 2.5s ease-in-out infinite; }
  .hero-badge { animation: hero-badge-in 1.2s cubic-bezier(0.22,1,0.36,1) 1.2s both; }
  .hero-bar { animation: hero-bar-enter 1.4s cubic-bezier(0.22,1,0.36,1) 0.4s both; }

  .hero-tilt { transition: transform 600ms var(--ease-luxury); will-change: transform; }
  .hero-stage:hover .hero-tilt { transform: perspective(1000px) rotateY(-3deg) rotateX(2deg); }

  .hero-parallax { will-change: transform; }

  @media (prefers-reduced-motion: reduce) {
    .hero-wave, .hero-float, .hero-ring, .hero-shimmer, .hero-spin-slow,
    .hero-coin-3d, .hero-coin-float, .hero-shine, .hero-scroll-hint,
    .hero-badge, .hero-bar { animation: none !important; }
  }
</style>
