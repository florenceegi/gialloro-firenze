---
/**
 * @package GIALLORO-FIRENZE — Nav
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Navigazione principale sticky luxury: logo, 10 link, lang switcher,
 *          mobile burger con panel full-screen. A11y: aria-expanded, aria-current.
 */
import { t, hrefFor, altLocale, alternateUrl, type Locale } from '@i18n/index';

export interface Props { locale: Locale; path: string; }
const { locale, path } = Astro.props;

const links = [
  { key: 'nav.compro_oro',  it: '/compro-oro',  en: '/en/sell-gold' },
  { key: 'nav.investimento',it: '/investimento',en: '/en/buy-gold' },
  { key: 'nav.gioielleria', it: '/gioielleria', en: '/en/jewelry' },
  { key: 'nav.quotazioni',  it: '/quotazioni',  en: '/en/live-price' },
  { key: 'nav.perizie',     it: '/perizie',     en: '/en/appraisals' },
  { key: 'nav.faq',         it: '/faq',         en: '/en/faq' },
  { key: 'nav.chi_siamo',   it: '/chi-siamo',   en: '/en/about' },
  { key: 'nav.contatti',    it: '/contatti',    en: '/en/contact' },
] as const;

const homeHref = hrefFor(locale, '/');
const altHref = alternateUrl(locale, path);
const alt = altLocale(locale);
---
<header class="site-header sticky top-0 z-50 bg-ivory-50/92 backdrop-blur-md border-b border-ink-200/60 no-print">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="h-16 md:h-20 flex items-center justify-between gap-4">

      <!-- Logo -->
      <a href={homeHref} class="flex items-center gap-3 group" aria-label={t(locale, 'meta.brand')}>
        <svg width="34" height="34" viewBox="0 0 44 44" fill="none" aria-hidden="true" class="transition-transform group-hover:rotate-[-4deg] duration-500">
          <circle cx="22" cy="22" r="20" stroke="var(--color-gold-500)" stroke-width="1.5" fill="var(--color-gold-50)"/>
          <path d="M22 8 L25 18 L35 18 L27 24 L30 34 L22 28 L14 34 L17 24 L9 18 L19 18 Z" fill="var(--color-gold-500)" stroke="var(--color-gold-700)" stroke-width="0.5" stroke-linejoin="round"/>
        </svg>
        <div class="leading-tight">
          <div class="serif text-base md:text-lg font-semibold tracking-tight">Giallo Oro Firenze</div>
          <div class="text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-ink-600">Banco Metalli · Gioielleria</div>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
        {links.map((l) => {
          const href = locale === 'it' ? l.it : l.en;
          const active = path === href;
          return (
            <a
              href={href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'px-3 py-2 text-[13px] font-medium tracking-wide transition-colors',
                active ? 'text-gold-700' : 'text-ink-800 hover:text-gold-700',
              ]}
            >
              {t(locale, l.key as any)}
            </a>
          );
        })}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-2 md:gap-3">
        <a href={altHref} hreflang={alt === 'it' ? 'it-IT' : 'en-US'} class="hidden md:inline-flex items-center gap-1.5 px-2.5 py-1.5 text-[11px] uppercase tracking-[0.2em] font-semibold text-ink-600 hover:text-gold-700 border border-ink-200 hover:border-gold-400 rounded-sm transition-colors">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"/></svg>
          {t(locale, 'nav.lang_switch')}
        </a>
        <a href="tel:+390552335573" class="hidden md:inline-flex items-center gap-2 text-[13px] font-semibold text-ink-800 hover:text-gold-700">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          055 2335573
        </a>
        <a href={hrefFor(locale, locale === 'it' ? 'contatti' : 'en/contact')} class="btn-gold !py-2.5 !px-5 text-[11px] md:text-xs">
          {t(locale, 'cta.appointment')}
        </a>

        <!-- Burger (mobile) -->
        <button type="button" class="lg:hidden w-10 h-10 inline-flex items-center justify-center rounded border border-ink-200 text-ink-900" aria-expanded="false" aria-controls="mobile-panel" aria-label={t(locale, 'nav.menu_open')} data-mobile-toggle>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile panel -->
  <div id="mobile-panel" class="lg:hidden fixed inset-0 top-16 bg-ivory-50 z-40 translate-x-full transition-transform duration-300 ease-out" aria-hidden="true" data-mobile-panel>
    <div class="p-6 flex flex-col gap-1 max-h-[calc(100vh-4rem)] overflow-y-auto">
      {links.map((l) => {
        const href = locale === 'it' ? l.it : l.en;
        const active = path === href;
        return (
          <a href={href} aria-current={active ? 'page' : undefined} class:list={[
            'serif text-2xl py-3 border-b border-ink-200',
            active ? 'text-gold-700' : 'text-ink-900'
          ]}>
            {t(locale, l.key as any)}
          </a>
        );
      })}
      <div class="mt-6 flex flex-col gap-3">
        <a href="tel:+390552335573" class="btn-ghost">{t(locale, 'cta.call')}</a>
        <a href="https://wa.me/393917792818" class="btn-gold" target="_blank" rel="noopener">{t(locale, 'cta.whatsapp')}</a>
        <a href={altHref} class="text-center mt-2 text-sm uppercase tracking-widest text-ink-600">{t(locale, 'nav.lang_switch')}</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    const btn = document.querySelector('[data-mobile-toggle]');
    const panel = document.querySelector('[data-mobile-panel]');
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      const open = panel.classList.toggle('translate-x-full') === false;
      btn.setAttribute('aria-expanded', String(open));
      panel.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    });
  })();
</script>
