---
/**
 * @package GIALLORO-FIRENZE — Section Heading
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Heading di sezione coerente: eyebrow + h2 serif + subtitle.
 *          Gold rule sottile come firma visiva.
 */
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  center?: boolean;
  as?: 'h1' | 'h2' | 'h3';
}
const { eyebrow, title, subtitle, center = true, as = 'h2' } = Astro.props;
const Tag = as;
---
<div class:list={['mb-12 md:mb-16', center && 'text-center mx-auto max-w-3xl']}>
  {eyebrow && (
    <div class:list={['inline-flex items-center gap-3 mb-4', center && 'justify-center']}>
      <span class="h-px w-8 bg-gold-500"></span>
      <span class="text-[11px] uppercase tracking-[0.28em] font-semibold text-gold-700">{eyebrow}</span>
      <span class="h-px w-8 bg-gold-500"></span>
    </div>
  )}
  <Tag class="serif text-4xl md:text-5xl lg:text-6xl text-ink-900 leading-tight">{title}</Tag>
  {subtitle && <p class="mt-5 text-lg text-ink-600 leading-relaxed">{subtitle}</p>}
</div>
