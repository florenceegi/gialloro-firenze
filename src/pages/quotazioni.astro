---
/**
 * @package GIALLORO-FIRENZE — Quotazioni IT
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Quotazioni oro e argento oggi. Dataset schema per AI citation,
 *          valori tipicamente estratti da Google SGE / Perplexity.
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import GoldQuoteTable from '@components/GoldQuoteTable.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema } from '@lib/schema';

const locale = 'it' as const;
const path = '/quotazioni';

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/' },
    { name: t(locale, 'nav.quotazioni'), url: 'https://gialloorofirenze.it/quotazioni' },
  ]),
];

const title = 'Quotazione oro Firenze oggi · Prezzo al grammo aggiornato';
const description = 'Quotazione oro 24kt, 22kt, 18kt, 14kt, 9kt e argento 925/800 al grammo a Firenze. Prezzi aggiornati ogni giorno sul London Gold Fixing. Perizia gratuita in negozio.';
---
<Base locale={locale} path={path} title={title} description={description} schema={schemas}>

  <section class="pt-20 md:pt-28 pb-12 bg-gradient-to-br from-ivory-50 to-gold-50/30">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
        <ol class="flex items-center gap-2">
          <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-800 font-medium">{t(locale, 'nav.quotazioni')}</li>
        </ol>
      </nav>
      <SectionHeading as="h1" eyebrow="Quotazione oggi" title={t(locale, 'quotes.title')} subtitle={t(locale, 'quotes.subtitle')} />
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <GoldQuoteTable locale={locale} />
    </div>
  </section>

  <section class="py-16 bg-ivory-50">
    <div class="max-w-3xl mx-auto px-4 md:px-8">
      <div class="p-8 border border-gold-200 rounded-sm bg-white shadow-gold-sm">
        <h2 class="serif text-2xl font-semibold text-ink-900 mb-4">Come calcoliamo il prezzo</h2>
        <ol class="space-y-3 text-ink-700 text-[16px] leading-relaxed list-decimal list-inside">
          <li>Quotazione London Gold Fixing del giorno (USD/oncia)</li>
          <li>Conversione in euro al cambio BCE corrente</li>
          <li>Calcolo prezzo al grammo per titolo (24kt / 22kt / 18kt / 14kt / 9kt)</li>
          <li>Sottrazione margine commerciale trasparente</li>
          <li>Verifica peso e titolo in negozio (pietra di paragone + bilancia certificata)</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white text-center">
    <div class="max-w-2xl mx-auto px-4 md:px-8">
      <h2 class="serif text-3xl text-ink-900 mb-4">Vuoi una valutazione personalizzata?</h2>
      <p class="text-ink-600 mb-8">Porta il tuo oro in negozio o mandaci una foto su WhatsApp: ti diamo una stima in tempo reale.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href={hrefFor(locale, 'contatti')} class="btn-gold">{t(locale, 'hero.cta_primary')}</a>
        <a href="https://wa.me/393917792818" class="btn-ghost">{t(locale, 'cta.whatsapp')}</a>
      </div>
    </div>
  </section>

</Base>
