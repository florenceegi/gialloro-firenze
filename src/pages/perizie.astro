---
/**
 * @package GIALLORO-FIRENZE — Perizie IT
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Perizie gemmologiche, lasciti ereditari, valutazioni assicurative.
 *          Answer-first AEO, Service schema.
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema, serviceSchema } from '@lib/schema';

const locale = 'it' as const;
const path = '/perizie';

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/' },
    { name: t(locale, 'nav.perizie'), url: 'https://gialloorofirenze.it/perizie' },
  ]),
  serviceSchema({
    name: 'Perizie gemmologiche e valutazioni',
    description: t(locale, 'perizie.answer'),
    serviceType: 'Gemological Appraisal',
    areaServed: 'Firenze, Toscana, Italia',
  }),
];

const title = 'Perizie gemmologiche Firenze · Lasciti, successioni, assicurazioni';
const description = t(locale, 'perizie.answer');

const items = [
  { t: 'perizie.gem_title', d: 'perizie.gem_text', icon: 'M12 2l4 6-4 14-4-14z' },
  { t: 'perizie.legacy_title', d: 'perizie.legacy_text', icon: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z M14 2v6h6' },
  { t: 'perizie.insurance_title', d: 'perizie.insurance_text', icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
];
---
<Base locale={locale} path={path} title={title} description={description} schema={schemas}>

  <section class="pt-20 md:pt-28 pb-12 bg-gradient-to-br from-ivory-50 to-gold-50/30">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
        <ol class="flex items-center gap-2">
          <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-800 font-medium">{t(locale, 'nav.perizie')}</li>
        </ol>
      </nav>
      <SectionHeading as="h1" eyebrow="Perizie" title={t(locale, 'perizie.title')} />
      <p class="text-xl text-ink-700 leading-relaxed max-w-3xl mx-auto text-center -mt-4">
        {t(locale, 'perizie.answer')}
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-8 grid md:grid-cols-3 gap-6">
      {items.map((it) => (
        <article class="card-lux p-7">
          <div class="w-14 h-14 rounded-sm bg-gold-50 border border-gold-200 text-gold-700 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={`<path d="${it.icon}"/>`} />
          </div>
          <h3 class="serif text-xl font-semibold text-ink-900 mb-3">{t(locale, it.t)}</h3>
          <p class="text-ink-600 text-[15px] leading-relaxed">{t(locale, it.d)}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-16 bg-ivory-50 text-center">
    <div class="max-w-2xl mx-auto px-4 md:px-8">
      <h2 class="serif text-3xl text-ink-900 mb-4">Prenota la perizia</h2>
      <p class="text-ink-600 mb-8">Stima orale gratuita. Documento scritto firmato con tariffa concordata prima.</p>
      <a href={hrefFor(locale, 'contatti')} class="btn-gold">{t(locale, 'cta.appointment')}</a>
    </div>
  </section>

</Base>
