---
/**
 * @package GIALLORO-FIRENZE — Blog post IT
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Render dinamico articolo blog IT. SSG getStaticPaths sugli entry it+!draft.
 *          BlogPosting schema + breadcrumb. Prose-lux per tipografia editoriale.
 */
import Base from '@layouts/Base.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema, blogPostingSchema } from '@lib/schema';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (e) => e.data.locale === 'it' && !e.data.draft);
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await post.render();

const locale = 'it' as const;
const path = `/blog/${post.slug}`;
const url = `https://gialloorofirenze.it${path}`;

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/' },
    { name: t(locale, 'nav.blog'), url: 'https://gialloorofirenze.it/blog' },
    { name: post.data.title, url },
  ]),
  blogPostingSchema({
    title: post.data.title,
    description: post.data.description,
    url,
    image: `https://gialloorofirenze.it${post.data.cover}`,
    datePublished: post.data.datePublished.toISOString(),
    dateModified: post.data.dateModified?.toISOString(),
    authorName: post.data.author,
    locale: 'it',
  }),
];
---
<Base locale={locale} path={path} title={post.data.title} description={post.data.description} schema={schemas} ogImage={post.data.cover} ogImageAlt={post.data.coverAlt}>

  <article>
    <header class="pt-20 md:pt-28 pb-10 bg-gradient-to-br from-ivory-50 to-gold-50/30">
      <div class="max-w-3xl mx-auto px-4 md:px-8">
        <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
          <ol class="flex items-center gap-2 flex-wrap">
            <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
            <li aria-hidden="true">/</li>
            <li><a href={hrefFor(locale, 'blog')} class="hover:text-gold-700">{t(locale, 'nav.blog')}</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-ink-800 font-medium line-clamp-1">{post.data.title}</li>
          </ol>
        </nav>
        <div class="text-[11px] uppercase tracking-[0.25em] text-gold-700 font-semibold mb-4">
          <time datetime={post.data.datePublished.toISOString()}>
            {post.data.datePublished.toLocaleDateString('it-IT', { day: '2-digit', month: 'long', year: 'numeric' })}
          </time>
          <span class="mx-2 text-ink-300">·</span>
          <span>{post.data.author}</span>
        </div>
        <h1 class="serif text-4xl md:text-5xl lg:text-6xl text-ink-900 leading-tight mb-6">{post.data.title}</h1>
        <p class="text-xl text-ink-700 leading-relaxed">{post.data.description}</p>
      </div>
    </header>

    {post.data.cover && (
      <div class="max-w-4xl mx-auto px-4 md:px-8 -mt-2 mb-10">
        <img src={post.data.cover} alt={post.data.coverAlt} width="1200" height="675" loading="eager" class="w-full aspect-[16/9] object-cover rounded-sm shadow-gold-md" />
      </div>
    )}

    <div class="max-w-3xl mx-auto px-4 md:px-8 pb-20">
      <div class="prose-lux">
        <Content />
      </div>

      <div class="gold-rule my-12"></div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={hrefFor(locale, 'contatti')} class="btn-gold">{t(locale, 'cta.appointment')}</a>
        <a href={hrefFor(locale, 'blog')} class="btn-ghost">← {t(locale, 'nav.blog')}</a>
      </div>
    </div>
  </article>

</Base>
