---
/**
 * @package GIALLORO-FIRENZE — Blog index IT (live CMS)
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 2.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-18
 * @purpose Lista articoli blog IT — SSR live da CMS Laravel (/api/v1/blog).
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema } from '@lib/schema';
import { fetchBlogList, formatDate } from '@lib/cms';

const locale = 'it' as const;
const path = '/blog';

const posts = await fetchBlogList(locale);

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/' },
    { name: t(locale, 'nav.blog'), url: 'https://gialloorofirenze.it/blog' },
  ]),
];

const title = `${t(locale, 'blog.title')} · Giallo Oro Firenze`;
const description = t(locale, 'blog.subtitle');
---
<Base locale={locale} path={path} title={title} description={description} schema={schemas}>

  <section class="pt-20 md:pt-28 pb-12 bg-gradient-to-br from-ivory-50 to-gold-50/30">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
        <ol class="flex items-center gap-2">
          <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-800 font-medium">{t(locale, 'nav.blog')}</li>
        </ol>
      </nav>
      <SectionHeading as="h1" eyebrow="News" title={t(locale, 'blog.title')} subtitle={t(locale, 'blog.subtitle')} />
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      {posts.length === 0 ? (
        <div class="max-w-xl mx-auto text-center p-10 border border-ink-200 rounded-sm bg-ivory-50">
          <h2 class="serif text-2xl text-ink-900 mb-3">Stiamo scrivendo il primo articolo</h2>
          <p class="text-ink-600 mb-6">Presto pubblicheremo guide su vendita oro, quotazioni storiche e storia del metallo. Nel frattempo, le nostre risposte sono già pronte nelle FAQ.</p>
          <a href={hrefFor(locale, 'faq')} class="btn-ghost">Vai alle FAQ</a>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((p) => (
            <a href={`/blog/${p.slug}`} class="card-lux p-0 overflow-hidden group">
              {p.featured_image && (
                <div class="aspect-[16/10] bg-ivory-100 overflow-hidden">
                  <img src={p.featured_image} alt={p.title} width="600" height="375" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
              )}
              <div class="p-6">
                {p.published_at && (
                  <time datetime={p.published_at} class="text-xs uppercase tracking-widest text-gold-700 font-semibold">
                    {formatDate(p.published_at, locale)}
                  </time>
                )}
                <h2 class="serif text-xl text-ink-900 mt-2 mb-3 group-hover:text-gold-700 transition-colors">{p.title}</h2>
                {p.excerpt && <p class="text-ink-600 text-[14.5px] leading-relaxed">{p.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Base>
