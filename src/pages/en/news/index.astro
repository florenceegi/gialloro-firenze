---
/**
 * @package GIALLORO-FIRENZE — Blog index EN
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose EN blog list with empty-state.
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema } from '@lib/schema';
import { getCollection } from 'astro:content';

const locale = 'en' as const;
const path = '/en/news';

const posts = (await getCollection('blog', (e) => e.data.locale === 'en' && !e.data.draft))
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime());

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/en' },
    { name: t(locale, 'nav.blog'), url: 'https://gialloorofirenze.it/en/news' },
  ]),
];

const title = `${t(locale, 'blog.title')} · Giallo Oro Firenze`;
const description = t(locale, 'blog.subtitle');
---
<Base locale={locale} path={path} title={title} description={description} schema={schemas}>
  <section class="pt-20 md:pt-28 pb-12 bg-gradient-to-br from-ivory-50 to-gold-50/30">
    <div class="max-w-5xl mx-auto px-4 md:px-8">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
        <ol class="flex items-center gap-2">
          <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-800 font-medium">{t(locale, 'nav.blog')}</li>
        </ol>
      </nav>
      <SectionHeading as="h1" eyebrow="News" title={t(locale, 'blog.title')} subtitle={t(locale, 'blog.subtitle')} />
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      {posts.length === 0 ? (
        <div class="max-w-xl mx-auto text-center p-10 border border-ink-200 rounded-sm bg-ivory-50">
          <h2 class="serif text-2xl text-ink-900 mb-3">Writing the first article</h2>
          <p class="text-ink-600 mb-6">We will soon publish guides on selling gold, historical quotes, and the metal's story. In the meantime, our answers are already in the FAQ.</p>
          <a href={hrefFor(locale, 'faq')} class="btn-ghost">Go to FAQ</a>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((p) => (
            <a href={`/en/news/${p.slug}`} class="card-lux p-0 overflow-hidden group">
              <div class="aspect-[16/10] bg-ivory-100 overflow-hidden">
                <img src={p.data.cover} alt={p.data.coverAlt} width="600" height="375" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-6">
                <time datetime={p.data.datePublished.toISOString()} class="text-xs uppercase tracking-widest text-gold-700 font-semibold">{p.data.datePublished.toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
                <h2 class="serif text-xl text-ink-900 mt-2 mb-3 group-hover:text-gold-700 transition-colors">{p.data.title}</h2>
                <p class="text-ink-600 text-[14.5px] leading-relaxed">{p.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
