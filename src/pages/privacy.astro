---
/**
 * @package GIALLORO-FIRENZE — Privacy IT
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Privacy Policy GDPR (Reg. UE 679/2016). Contenuto da rivedere con
 *          consulente legale prima del go-live produzione.
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { t, hrefFor } from '@i18n/index';
import { BUSINESS } from '@lib/schema';

const locale = 'it' as const;
const path = '/privacy';
const title = 'Privacy Policy · Giallo Oro Firenze';
const description = 'Informativa sul trattamento dei dati personali ai sensi del GDPR (Reg. UE 679/2016).';
---
<Base locale={locale} path={path} title={title} description={description} noindex={true}>
  <article class="prose-lux py-20 md:py-24 max-w-3xl mx-auto px-4 md:px-8">
    <SectionHeading as="h1" eyebrow="Informativa" title="Privacy Policy" center={false} />

    <p><strong>Titolare del trattamento:</strong> {BUSINESS.legalName}<br/>
    {BUSINESS.address.streetAddress}, {BUSINESS.address.postalCode} {BUSINESS.address.addressLocality}<br/>
    Email: <a href={`mailto:${BUSINESS.email}`} class="text-gold-700">{BUSINESS.email}</a> · P.IVA {BUSINESS.vatId}</p>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Dati raccolti</h2>
    <p>Raccogliamo i dati che ci fornisci volontariamente compilando il modulo di contatto (nome, email, telefono, messaggio) e i dati di navigazione tecnici (indirizzo IP, browser, pagine visitate) necessari al funzionamento del sito.</p>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Finalità</h2>
    <ul class="list-disc pl-6 space-y-2">
      <li>Rispondere alle tue richieste di valutazione o informazione</li>
      <li>Adempimenti normativi OAM (antiriciclaggio) in caso di transazioni</li>
      <li>Monitoraggio statistico anonimo del sito</li>
    </ul>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Base giuridica</h2>
    <p>Consenso esplicito al momento dell'invio del modulo (art. 6.1.a GDPR) · obbligo legale OAM per le transazioni (art. 6.1.c).</p>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Conservazione</h2>
    <p>I dati del modulo di contatto sono conservati per 24 mesi dall'ultimo contatto. I dati transazionali OAM sono conservati per 10 anni come da normativa.</p>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Diritti dell'interessato</h2>
    <p>Hai diritto di accesso, rettifica, cancellazione, limitazione, portabilità, opposizione (artt. 15-22 GDPR). Per esercitarli scrivi a <a href={`mailto:${BUSINESS.email}`} class="text-gold-700">{BUSINESS.email}</a>. Hai inoltre il diritto di proporre reclamo al Garante Privacy (garanteprivacy.it).</p>

    <h2 class="serif text-2xl text-ink-900 mt-10 mb-4">Cookie</h2>
    <p>Per dettagli sui cookie utilizzati consulta la <a href={hrefFor(locale, 'cookie')} class="text-gold-700">Cookie Policy</a>.</p>

    <p class="text-sm text-ink-500 mt-12">Ultimo aggiornamento: 2026-04-17</p>
  </article>
</Base>
