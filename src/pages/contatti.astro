---
/**
 * @package GIALLORO-FIRENZE — Contatti IT
 * @author Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici
 * @version 1.0.0 (FlorenceEGI — GIALLORO-FIRENZE)
 * @date 2026-04-17
 * @purpose Pagina contatti IT. Form + info negozio + orari + mappa + CTA diretti.
 *          NAP (Name/Address/Phone) coerente con schema LocalBusiness (GEO).
 */
import Base from '@layouts/Base.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ContactForm from '@components/ContactForm.astro';
import { t, hrefFor } from '@i18n/index';
import { breadcrumbSchema, BUSINESS } from '@lib/schema';

const locale = 'it' as const;
const path = '/contatti';

const schemas = [
  breadcrumbSchema([
    { name: t(locale, 'nav.home'), url: 'https://gialloorofirenze.it/' },
    { name: t(locale, 'nav.contatti'), url: 'https://gialloorofirenze.it/contatti' },
  ]),
];

const title = `Contatti · Giallo Oro Firenze`;
const description = 'Contatta Giallo Oro Firenze: Via del Ponte Sospeso 31, Firenze. Telefono 055 2335573, WhatsApp, email info@gialloorofirenze.it. Perizia gratuita in negozio.';

const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${BUSINESS.geo.latitude},${BUSINESS.geo.longitude}`;
const mapsEmbed = `https://maps.google.com/maps?q=${BUSINESS.geo.latitude},${BUSINESS.geo.longitude}&z=16&output=embed`;
---
<Base locale={locale} path={path} title={title} description={description} schema={schemas}>

  <section class="pt-20 md:pt-28 pb-12 bg-gradient-to-br from-ivory-50 to-gold-50/30">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-ink-500">
        <ol class="flex items-center gap-2">
          <li><a href={hrefFor(locale, '')} class="hover:text-gold-700">{t(locale, 'nav.home')}</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-ink-800 font-medium">{t(locale, 'nav.contatti')}</li>
        </ol>
      </nav>
      <SectionHeading
        as="h1"
        eyebrow="Contatti"
        title="Passa in negozio, chiama o scrivi"
        subtitle="Perizia gratuita e senza impegno. Ti rispondiamo entro 4 ore in orario di ufficio."
      />
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

      {/* LEFT: info negozio */}
      <div class="space-y-10">

        {/* Address */}
        <div>
          <h3 class="serif text-xl font-semibold text-ink-900 mb-4 flex items-center gap-3">
            <svg class="text-gold-600" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {t(locale, 'contact.address_title')}
          </h3>
          <address class="not-italic text-ink-600 text-[17px] leading-relaxed mb-3">
            <strong class="text-ink-900 block">{BUSINESS.legalName}</strong>
            {BUSINESS.address.streetAddress}<br/>
            {BUSINESS.address.postalCode} {BUSINESS.address.addressLocality}<br/>
            P.IVA {BUSINESS.vatId}
          </address>
          <a href={mapsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-gold-700 font-semibold text-sm uppercase tracking-wider hover:text-gold-800">
            {t(locale, 'cta.directions')}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        </div>

        {/* Hours */}
        <div>
          <h3 class="serif text-xl font-semibold text-ink-900 mb-4 flex items-center gap-3">
            <svg class="text-gold-600" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {t(locale, 'contact.hours_title')}
          </h3>
          <ul class="space-y-2 text-ink-600 text-[16px]">
            <li class="flex gap-4">
              <span class="text-ink-400 font-mono text-sm w-14 flex-shrink-0 pt-0.5">Lun-Ven</span>
              <span>{t(locale, 'contact.hours_week')}</span>
            </li>
            <li class="flex gap-4">
              <span class="text-ink-400 font-mono text-sm w-14 flex-shrink-0 pt-0.5">Gio</span>
              <span>{t(locale, 'contact.hours_thu')}</span>
            </li>
            <li class="flex gap-4">
              <span class="text-ink-400 font-mono text-sm w-14 flex-shrink-0 pt-0.5">Sab-Dom</span>
              <span class="text-ink-500">{t(locale, 'contact.hours_sat')}</span>
            </li>
          </ul>
        </div>

        {/* Direct */}
        <div>
          <h3 class="serif text-xl font-semibold text-ink-900 mb-4 flex items-center gap-3">
            <svg class="text-gold-600" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z"/></svg>
            Contatti diretti
          </h3>
          <div class="space-y-3">
            <a href="tel:+390552335573" class="flex items-center gap-3 text-ink-700 hover:text-gold-700 transition-colors group">
              <span class="text-ink-400 text-xs uppercase tracking-wider w-24">{t(locale, 'contact.phone_label')}</span>
              <span class="font-mono font-semibold">055 2335573</span>
            </a>
            <a href="tel:+393917792818" class="flex items-center gap-3 text-ink-700 hover:text-gold-700 transition-colors">
              <span class="text-ink-400 text-xs uppercase tracking-wider w-24">{t(locale, 'contact.mobile_label')}</span>
              <span class="font-mono font-semibold">+39 391 7792818</span>
            </a>
            <a href={`mailto:${BUSINESS.email}`} class="flex items-center gap-3 text-ink-700 hover:text-gold-700 transition-colors">
              <span class="text-ink-400 text-xs uppercase tracking-wider w-24">{t(locale, 'contact.email_label')}</span>
              <span class="font-mono font-semibold">{BUSINESS.email}</span>
            </a>
            <a href="https://wa.me/393917792818" target="_blank" rel="noopener" class="flex items-center gap-3 text-emerald-700 hover:text-emerald-800 transition-colors">
              <span class="text-ink-400 text-xs uppercase tracking-wider w-24">WhatsApp</span>
              <span class="font-semibold">Scrivi su WhatsApp</span>
            </a>
          </div>
        </div>

        {/* Parking */}
        <div>
          <h3 class="serif text-xl font-semibold text-ink-900 mb-4 flex items-center gap-3">
            <svg class="text-gold-600" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M10 16V8h4a2 2 0 010 4h-4"/></svg>
            {t(locale, 'contact.parking_title')}
          </h3>
          <p class="text-ink-600 text-[16px] leading-relaxed">{t(locale, 'contact.parking_text')}</p>
        </div>

      </div>

      {/* RIGHT: form */}
      <div class="lg:sticky lg:top-24 lg:self-start">
        <ContactForm locale={locale} />
      </div>

    </div>
  </section>

  {/* MAP */}
  <section class="bg-ink-900">
    <div class="max-w-7xl mx-auto">
      <div class="aspect-[21/9] md:aspect-[21/7]">
        <iframe
          src={mapsEmbed}
          class="w-full h-full border-0 grayscale-[30%]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mappa negozio Giallo Oro Firenze"
          aria-label="Mappa posizione Giallo Oro Firenze — Via del Ponte Sospeso 31, Firenze"
        />
      </div>
    </div>
  </section>

</Base>
